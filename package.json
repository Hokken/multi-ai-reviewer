{
  "name": "multi-ai-reviewer",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI-first multi-LLM author/reviewer workflow tool for Claude Code, Codex CLI, and Gemini CLI.",
  "bin": {
    "mrev": "./dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && chmod +x dist/src/cli/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
